{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "noEmit": true,
    // .d.ts union 멤버를 결정적으로 정렬 — tsdown 기본 tsc dts 경로는 공유 checker에
    // rolldown이 모듈을 병렬(비결정)로 넘겨 CVA VariantProps union 순서가 재빌드마다
    // 뒤섞임. 이 플래그로 순서를 안정화해 dist/CI freshness 게이트를 결정적으로 유지.
    "stableTypeOrdering": true,
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src"]
}
